{
  "name": "email-automation-workspace",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=frontend\" \"npm run start --workspace=backend\"",
    "build:frontend": "npm run build --workspace=frontend",
    "lint:frontend": "npm run lint --workspace=frontend",
    "start:backend": "npm run start --workspace=backend",
    "test:unit": "npm run test:unit --workspace=backend",
    "test:integration": "npm run test:integration --workspace=backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
